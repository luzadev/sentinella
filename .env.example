# ---- Control plane (copy to control-plane/.env) ----
# Tutte le variabili usano il prefisso SENTINELLA_

# Sicurezza — CAMBIALE in produzione
SENTINELLA_SECRET_KEY=genera-una-stringa-lunga-e-casuale
SENTINELLA_ADMIN_USERNAME=admin
SENTINELLA_ADMIN_PASSWORD=cambia-questa-password

# Token che gli agent presentano per registrarsi
SENTINELLA_AGENT_ENROLL_TOKEN=enroll-cambia-questo-token

# Database (default: SQLite locale).
# MariaDB / MySQL (es. Virtualmin):
#   SENTINELLA_DATABASE_URL=mysql+pymysql://sentinella:PASSWORD@localhost:3306/sentinella
# Postgres:
#   SENTINELLA_DATABASE_URL=postgresql+psycopg://user:pass@db:5432/sentinella
SENTINELLA_DATABASE_URL=sqlite:///./sentinella.db

# Telegram — crea un bot con @BotFather e ricava il chat_id
SENTINELLA_TELEGRAM_BOT_TOKEN=
SENTINELLA_TELEGRAM_CHAT_ID=

# AI remediation (Anthropic)
SENTINELLA_ANTHROPIC_API_KEY=
SENTINELLA_AI_MODEL=claude-sonnet-4-6
SENTINELLA_AI_ENABLED=true

# Quanti secondi senza heartbeat prima di marcare un server offline
SENTINELLA_OFFLINE_AFTER_SECONDS=90
